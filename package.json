{
  "name": "@xdsjs/llm-wiki-invest",
  "version": "0.0.4",
  "description": "Agent-native LLM Wiki Invest — AI-maintained knowledge base with Obsidian compatibility",
  "type": "module",
  "bin": {
    "llm-wiki-invest": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release:patch": "npm test && npm version patch && git push origin main --tags",
    "release:minor": "npm test && npm version minor && git push origin main --tags",
    "release:major": "npm test && npm version major && git push origin main --tags"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "ai",
    "obsidian",
    "agent"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xdsjs/llm-invest-wiki.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "skills"
  ],
  "dependencies": {
    "commander": "^13.0.0",
    "defuddle": "^0.18.1",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12",
    "pdf-parse": "^1.1.4",
    "toml": "^3.0.0"
  },
  "optionalDependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
