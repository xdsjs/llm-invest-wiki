{
  "manifest_version": 3,
  "name": "LLM Wiki Web Clipper",
  "version": "0.1.0",
  "description": "Clip web pages to your LLM Wiki",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
